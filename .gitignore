# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your OS
.DS_Store

# dotenv
.env

# Rails master key
/config/master.key

# Bundler
/vendor/bundle

# SQLite databases
/storage/*.sqlite3
/storage/*.sqlite3-*

# Log files
/log/*
!/log/.keep

# Temp files
/tmp/*
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep

# Bootsnap cache
/tmp/cache/bootsnap*
